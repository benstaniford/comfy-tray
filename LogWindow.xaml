<Window x:Class="ComfyTray.LogWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ComfyUI Logs" Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="LogBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="False"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="12"
                 BorderThickness="0"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="8">
            <CheckBox x:Name="AutoScroll"
                      Content="Auto-scroll"
                      Foreground="#D4D4D4"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Margin="0,0,12,0"/>
            <Button Content="Clear" Width="80" Margin="0,0,8,0" Click="Clear_Click"/>
            <Button Content="Close" Width="80" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>

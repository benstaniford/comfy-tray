<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductVersion="1.0.0.0" ?>
  <?define ProductName="ComfyUI Tray" ?>
  <?define Manufacturer="ComfyUI Tray" ?>
  <?define UpgradeCode="AB6EE5DF-3A05-478E-92A7-49E82533AEB7" ?>

  <Product Id="*"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Description="$(var.ProductName) Installer"
             Comments="Runs the ComfyUI server in the system tray" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="ComfyTray">
          <Directory Id="IconsFolder" Name="icons" />
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="ComfyUI Tray"/>
      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <!-- Components -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="ComfyTrayExe" Guid="{06097700-8AE3-4AAE-90BB-03C28C7F9B9D}">
        <File Id="ComfyTrayEXE"
              Source="$(var.ComfyTray.TargetDir)ComfyTray.exe"
              KeyPath="yes"
              Checksum="yes" />
        <File Id="ComfyTrayDLL"
              Source="$(var.ComfyTray.TargetDir)ComfyTray.dll" />
        <File Id="ComfyTrayRuntimeConfigJson"
              Source="$(var.ComfyTray.TargetDir)ComfyTray.runtimeconfig.json" />
        <File Id="ComfyTrayDepsJsonFile"
              Source="$(var.ComfyTray.TargetDir)ComfyTray.deps.json" />
      </Component>

      <!-- NuGet Dependencies - H.NotifyIcon -->
      <Component Id="HNotifyIcon" Guid="{7314F763-4B74-4191-BA5C-D6130DEBBEE6}">
        <File Id="HNotifyIconWpfDll"
              Source="$(var.ComfyTray.TargetDir)H.NotifyIcon.Wpf.dll"
              KeyPath="yes" />
      </Component>

      <Component Id="HNotifyIconCore" Guid="{0984632A-088A-4F72-B0E9-486EF7989AE3}">
        <File Id="HNotifyIconDll"
              Source="$(var.ComfyTray.TargetDir)H.NotifyIcon.dll"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Icons folder component -->
    <DirectoryRef Id="IconsFolder">
      <Component Id="IconsComponent" Guid="{EDAE4C34-8B83-4DD9-9170-0D9E451FF154}">
        <File Id="AppIco"
              Source="$(var.ComfyTray.TargetDir)icons\app.ico"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu Shortcut -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="{7DD0237D-E7C1-496A-9C6B-F446A111C808}">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="ComfyUI Tray"
                  Description="Runs the ComfyUI server in the system tray"
                  Target="[INSTALLFOLDER]ComfyTray.exe"
                  WorkingDirectory="INSTALLFOLDER"/>
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\ComfyTray"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Desktop Shortcut (Optional) -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="{122EC7FD-1500-4593-AE68-E15D9AB7ABEB}">
        <Shortcut Id="DesktopShortcut"
                  Name="ComfyUI Tray"
                  Description="Runs the ComfyUI server in the system tray"
                  Target="[INSTALLFOLDER]ComfyTray.exe"
                  WorkingDirectory="INSTALLFOLDER"/>
        <RemoveFolder Id="CleanUpDesktopShortcut" Directory="DesktopFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\ComfyTray"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Registry entry for Run at startup -->
    <DirectoryRef Id="TARGETDIR">
      <Component Id="RegistryEntries" Guid="{703A1316-27CF-4E72-AD01-BC7FCC9E532F}">
        <RegistryKey Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run">
          <RegistryValue Name="ComfyTray" Value="[INSTALLFOLDER]ComfyTray.exe" Type="string" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="ComfyUI Tray" Level="1">
      <ComponentRef Id="ComfyTrayExe" />
      <ComponentRef Id="IconsComponent" />
      <ComponentRef Id="HNotifyIcon" />
      <ComponentRef Id="HNotifyIconCore" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut" Level="1">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Auto-start with Windows -->
    <Feature Id="AutoStartFeature" Title="Start with Windows" Level="1">
      <ComponentRef Id="RegistryEntries" />
    </Feature>

    <!-- Custom Action to launch app after installation -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch ComfyUI Tray" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#ComfyTrayEXE]" />

    <CustomAction Id="LaunchApplication"
                  BinaryKey="WixCA"
                  DllEntry="WixShellExec"
                  Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed
      </Custom>
    </InstallExecuteSequence>

    <!-- UI -->
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Icons -->
    <Icon Id="app.ico" SourceFile="$(var.ComfyTray.TargetDir)icons\app.ico"/>
    <Property Id="ARPPRODUCTICON" Value="app.ico" />
  </Product>
</Wix>
